<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_mix_audio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mix_audio"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:padding="16dp" />
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mix_audio_desc"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_play_local"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_play_local"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:padding="16dp" />
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_play_local_desc"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

</LinearLayout>
