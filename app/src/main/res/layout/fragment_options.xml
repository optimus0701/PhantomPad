<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_mix_audio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mix_audio"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:padding="16dp" />
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mix_audio_desc"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_play_local"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_play_local"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:padding="16dp" />
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_play_local_desc"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- ═══ Mic Boost Section ═══ -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mic_boost"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <TextView
        android:id="@+id/tv_mic_boost_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/opt_mic_boost_desc"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp">

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_mic_boost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="1.0"
            android:valueTo="3.0"
            android:stepSize="0.1" />

        <TextView
            android:id="@+id/tv_mic_boost_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- ═══ Advanced Audio Settings Toggle ═══ -->

    <LinearLayout
        android:id="@+id/btn_advanced_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/iv_advanced_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="expand"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opt_advanced_audio"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorPrimary" />
    </LinearLayout>

    <!-- ═══ Advanced Audio Settings Panel (Collapsed by default) ═══ -->

    <LinearLayout
        android:id="@+id/panel_advanced"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:background="?android:attr/colorBackgroundFloating">

        <!-- Boost File Audio (moved from standalone) -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_boost_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_boost_file"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_boost_file_desc"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Noise Gate Threshold Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_gate_threshold"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_gate_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="-60.0"
                android:valueTo="-20.0"
                android:stepSize="1.0" />

            <TextView
                android:id="@+id/tv_gate_threshold_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-40 dB"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_gate_threshold_desc"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Compressor Threshold Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_comp_threshold"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_comp_threshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="-40.0"
                android:valueTo="0.0"
                android:stepSize="1.0" />

            <TextView
                android:id="@+id/tv_comp_threshold_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-20 dB"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_comp_threshold_desc"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Compressor Ratio Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_comp_ratio"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_comp_ratio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="1.0"
                android:valueTo="20.0"
                android:stepSize="0.5" />

            <TextView
                android:id="@+id/tv_comp_ratio_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4:1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/opt_comp_ratio_desc"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
</ScrollView>
